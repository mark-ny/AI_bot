# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Forex data APIs (use one or both, both have free tiers)
TWELVE_DATA_API_KEY=your-twelve-data-api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-channel-chat-id

# App settings
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
SECRET_KEY=a-very-long-random-secret-key-min-32-chars

# Model storage path (Render uses ephemeral disk — model is retrained and cached in-memory)
MODEL_PATH=./models
